[user]
 	name = Philippe Gaultier
 	email = philippe.gaultier@ory.sh
[alias]
	cof = !git for-each-ref --format='%(refname:short)' refs/heads | fzf | xargs git checkout
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[core]
	excludesfile = ~/.gitignore
	pager = delta
	editor = nvim
	autocrlf = input
[color]
	pager = no
[delta]
	navigate = true
	light = true
	line-numbers = true
  syntax-theme = gruvbox-light
	side-by-side = false
[init]
	defaultBranch = master
[scalar]
	repo = /Users/philippe.gaultier/company-code/cloud
	repo = /Users/philippe.gaultier/company-code/cloud2/src
[maintenance]
	repo = /Users/philippe.gaultier/company-code/cloud
	repo = /Users/philippe.gaultier/company-code/cloud2/src
	repo = /Users/philippe.gaultier/my-code/blog
	repo = /Users/philippe.gaultier/company-code/cloud3

# Add in the git repository a `.gitattributes` file with e.g.:
# `*.bin binary diff=hex`
[diff "hex"]
    textconv = hexdump -v -C
		binary = true
