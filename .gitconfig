[user]
 	name = Philippe Gaultier
 	email = philippe.gaultier@gi-de.com
[alias]
	cof = !git for-each-ref --format='%(refname:short)' refs/heads | fzf | xargs git checkout
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[core]
	excludesfile = /home/pg/.gitignore
	pager = delta
	editor = nvim
[color]
	pager = no
[delta]
	navigate = true
	light = true
	line-numbers = true
  syntax-theme = gruvbox-light
[init]
	defaultBranch = master
[url "git@ssh.dev.azure.com:v3/"]
        insteadOf = https://dev.azure.com/
[url "git@ssh.dev.azure.com:v3/advance52/"]
	insteadOf = https://dev.azure.com/advance52/
[url "git@ssh.dev.azure.com:v3/advance52"]
	insteadOf = git://dev.azure.com/advance52
[scalar]
	repo = /home/pg/not-my-code/llvm-project
	repo = /home/pg/not-my-code/buck2/src
	repo = /home/pg/not-my-code/neovim/src
	repo = /home/pg/not-my-code/rust/src
[maintenance]
	repo = /home/pg/not-my-code/llvm-project
	repo = /home/pg/not-my-code/buck2/src
	repo = /home/pg/not-my-code/neovim/src
	repo = /home/pg/not-my-code/rust/src
