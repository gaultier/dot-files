{
  "inlayHint.enableParameter": false,
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
      "args": [
        "serve"
      ],
      "filetypes": [
        "terraform",
        "tf"
      ],
      "initializationOptions": {}
    },
    "golang": {
      "command": "gopls",
      "rootPatterns": [
        "go.mod"
      ],
      "filetypes": [
        "go"
      ],
      "settings": {
        "codelenses": {
          "tidy": true,
          "gc_details": true // Show a code lens toggling the display of gc's choices.
        },
        "buildFlags": [
          "-tags=rabbitmq,integration"
        ]
      },
      "initializationOptions": {
        "buildFlags": [
          "-tags=rabbitmq,integration"
        ]
      },
    },
    "clangd": {
      "disableSnippetCompletion": true,
      "command": "/usr/local/opt/llvm/bin/clangd",
      "rootPatterns": [
        "compile_flags.txt",
        "compile_commands.json"
      ],
      "filetypes": [
        "c",
        "cc",
        "cpp",
        "c++",
        "objc",
        "objcpp"
      ]
    }
  }
}
